# LinkedIn OAuth app credentials — get these from developer.linkedin.com
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret

# Optional: port for the OAuth loopback redirect (default: 53123)
# Must match the redirect URI registered on your LinkedIn app
LINKEDIN_OAUTH_PORT=53123

# Where to read/write the OAuth token file (default: ./token.json)
LINKEDIN_TOKEN_PATH=./token.json

# Default ad account numeric ID (from Campaign Manager URL /accounts/<id>/)
# Tools accept ad_account_id as a parameter; this is the fallback
LINKEDIN_DEFAULT_AD_ACCOUNT=123456789

# LinkedIn Rosetta API version — format YYYYMM (default: 202504)
# LinkedIn versions deprecate after ~12 months. Bump quarterly.
LINKEDIN_API_VERSION=202504
